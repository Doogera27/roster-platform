# Server
PORT=4000
NODE_ENV=development

# Database
DATABASE_URL=postgresql://roster:roster@localhost:5432/roster
DATABASE_SSL=false

# Redis
REDIS_URL=redis://localhost:6379

# Auth0
AUTH0_DOMAIN=your-tenant.auth0.com
AUTH0_AUDIENCE=https://api.rosterteam.com
AUTH0_CLIENT_ID=your-client-id
AUTH0_CLIENT_SECRET=your-client-secret
AUTH0_MGMT_CLIENT_ID=your-mgmt-client-id
AUTH0_MGMT_CLIENT_SECRET=your-mgmt-client-secret

# AWS S3
AWS_REGION=us-east-1
AWS_S3_BUCKET=roster-assets
AWS_CLOUDFRONT_DOMAIN=d1234567890.cloudfront.net

# Stripe
STRIPE_SECRET_KEY=sk_test_...
STRIPE_WEBHOOK_SECRET=whsec_...
STRIPE_CONNECT_CLIENT_ID=ca_...

# Stream Chat
STREAM_API_KEY=your-stream-key
STREAM_API_SECRET=your-stream-secret

# Anthropic (Claude)
ANTHROPIC_API_KEY=sk-ant-...

# SendGrid
SENDGRID_API_KEY=SG....
SENDGRID_FROM_EMAIL=notifications@rosterteam.com

# Sentry
SENTRY_DSN=https://...@sentry.io/...
